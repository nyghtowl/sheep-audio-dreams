# Dialogue + Lyra's voice (gpt-4o-audio-preview — covers both dialogue and TTS for Lyra)
OPENAI_API_KEY=

# Zara's voice (gemini-2.0-flash-exp native audio — get free key at aistudio.google.com)
GEMINI_API_KEY=

# Optional: Claude for dialogue (overrides OpenAI for text generation)
ANTHROPIC_API_KEY=

# Optional: ElevenLabs for voice (fallback TTS when not using native speech models)
ELEVENLABS_API_KEY=

# Optional: force Google TTS for all voices (free, no API key)
# USE_GTTS=1

# Optional: force mock mode (scripted lines + silent audio, no API calls)
# MOCK_MODE=1
